PORT=3001
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-random-32-plus-character-string
LOG_LEVEL=info

# UI login password — checked at login time (independent of SSH)
PORTAL_PASS=your-ui-password

# SSH connection — used for all server operations after login.
SSH_HOST=192.168.1.100
SSH_PORT=22
SSH_USERNAME=ubuntu
SSH_PASSWORD=your-ssh-password

# CORS — set to your frontend URL when deploying frontend and server separately.
# Comma-separate multiple origins: https://app.example.com,https://www.example.com
# Leave unset when serving frontend as static files from this server.
# CORS_ORIGIN=https://your-frontend.vercel.app
